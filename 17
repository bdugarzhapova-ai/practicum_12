def function1(x):
    """
    Определяет, является ли натуральное число x простым
    """
    if x < 2:
        return 0
    if x == 2:
        return 1

    def is_prime(n, divisor):
        if divisor * divisor > n:
            return 1
        if n % divisor == 0:
            return 0
        return is_prime(n, divisor + 1)

    return is_prime(x, 2)


print(function1(2))
